set positional-arguments
set script-interpreter := ['uv', 'run', '--no-project', '--', 'python']

@_:
  just --list

_require-uv:
  @uv --version > /dev/null || (echo "Please install uv: https://docs.astral.sh/uv/" && exit 1)

# check code style and potential issues
lint: _require-uv
  uv run --group dev ruff check .

# format code
format: _require-uv
  uv run --group dev ruff format .

# check code formatting without modifying files
format-check: _require-uv
  uv run --group dev ruff format --check .

# fix automatically fixable linting issues
fix: _require-uv
  uv run --group dev ruff check --fix .

# run tests across all supported Python versions
[script]
test *args: _require-uv
  from pathlib import Path
  import os
  import shutil
  import subprocess
  import sys

  versions = [
      line.strip()
      for line in Path(".python-versions").read_text(encoding="utf-8").splitlines()
      if line.strip() and not line.lstrip().startswith("#")
  ]
  args = sys.argv[1:]
  if args[:1] == ["--"]:
      args = args[1:]

  def colorize(text):
      if os.environ.get("NO_COLOR"):
          return text
      if os.environ.get("FORCE_COLOR") or (sys.stdout.isatty() and os.environ.get("TERM") != "dumb"):
          return f"\033[1;36m{text}\033[0m"
      return text

  def print_separator(label):
      width = shutil.get_terminal_size(fallback=(120, 24)).columns
      text = f" {label} "
      if len(text) >= width:
          print(colorize(label), flush=True)
          return

      left = (width - len(text)) // 2
      right = width - len(text) - left
      print(colorize(f"{'─' * left}{text}{'─' * right}"), flush=True)

  def has_test_files():
      tests_dir = Path("tests")
      return tests_dir.exists() and any(
          path.is_file()
          for pattern in ("test_*.py", "*_test.py")
          for path in tests_dir.rglob(pattern)
      )

  if not args and not has_test_files():
      print("No tests found; skipping pytest.", flush=True)
      raise SystemExit(0)

  for py in versions:
      print_separator(f"Python {py}")
      result = subprocess.run([
          "uv",
          "run",
          "--python",
          py,
          "--isolated",
          "--group",
          "test",
          "--",
          "pytest",
          *args,
      ])
      if result.returncode:
          raise SystemExit(result.returncode)

# build the package
build: _require-uv
  uv build
{% if setup_readthedocs %}
# build the documentation site locally
docs: _require-uv
  uv run --extra docs sphinx-build -W --keep-going -b html docs docs/_build/html

# build and serve the documentation site locally
[script]
docs-serve port="8000": _require-uv
  import errno
  import functools
  import http.server
  import socketserver
  import subprocess
  import sys
  from pathlib import Path

  try:
      requested_port = int(sys.argv[1])
  except ValueError:
      raise SystemExit("Port must be an integer.") from None
  if not 0 <= requested_port <= 65535:
      raise SystemExit("Port must be between 0 and 65535.")

  build_dir = Path("docs/_build/html")
  subprocess.run(
      [
          "uv",
          "run",
          "--extra",
          "docs",
          "sphinx-build",
          "-W",
          "--keep-going",
          "-b",
          "html",
          "docs",
          str(build_dir),
      ],
      check=True,
  )

  class ReusableTCPServer(socketserver.TCPServer):
      allow_reuse_address = True

  handler = functools.partial(http.server.SimpleHTTPRequestHandler, directory=str(build_dir))
  port = requested_port
  while True:
      try:
          httpd = ReusableTCPServer(("127.0.0.1", port), handler)
          break
      except OSError as error:
          if error.errno != errno.EADDRINUSE or port == 0 or port >= 65535:
              raise
          print(f"Port {port} is in use; trying {port + 1}...", flush=True)
          port += 1

  host, actual_port = httpd.server_address
  print(f"Serving documentation at http://{host}:{actual_port}/", flush=True)
  try:
      httpd.serve_forever()
  except KeyboardInterrupt:
      print("\nStopped documentation server.")
{% endif %}
# setup or update local dev environment, keeps previously installed packages
sync: _require-uv
  uv sync --inexact --group dev
  uv run --group dev pre-commit install

# run tests with coverage and show a coverage report
[script]
coverage: _require-uv
  from pathlib import Path
  import subprocess

  tests_dir = Path("tests")
  has_test_files = tests_dir.exists() and any(
      path.is_file()
      for pattern in ("test_*.py", "*_test.py")
      for path in tests_dir.rglob(pattern)
  )
  if not has_test_files:
      print("No tests found; skipping coverage.", flush=True)
      raise SystemExit(0)

  subprocess.run(["uv", "run", "coverage", "run", "-m", "pytest"], check=True)
  subprocess.run(["uv", "run", "coverage", "report"], check=True)

# clean build artifacts and caches
clean:
  rm -rf .venv .pytest_cache .pyrefly .ruff_cache
  find . -type d -name "__pycache__" -exec rm -r {} +

# static type check with pyrefly
typecheck: _require-uv
  uv run --group dev pyrefly check --min-severity warn

# check code for common misspellings
spell: _require-uv
  uv run --group dev codespell

# run all non-mutating quality checks
check: lint format-check test typecheck

# list available recipes
help:
  just --list

alias fmt := format
alias cov := coverage
{% if setup_readthedocs %}
alias serve-docs := docs-serve
{% endif %}
alias pyrefly := typecheck
alias dev := sync

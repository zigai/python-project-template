{%- set SPDX_LICENSE_EXPRESSION_MAP = {
    "GPL-3.0": "GPL-3.0-only",
    "GPL-2.0": "GPL-2.0-only",
    "AGPL-3.0": "AGPL-3.0-only",
    "LGPL-3.0": "LGPL-3.0-only",
    "LGPL-2.1": "LGPL-2.1-only"
} -%}
[project]
name = "{{ package_name }}"
version = "0.1.0"
description = "{{ description }}"
{%- if author_name or author_email %}
authors = [{{ "{" }}{%- if author_name -%}name = "{{ author_name }}"{%- endif -%}{%- if author_name and author_email -%}, {% endif -%}{%- if author_email -%}email = "{{ author_email }}"{%- endif -%}{{ "}" }}]
{%- endif %}
{%- if copyright_license != "None" %}
license = "{{ SPDX_LICENSE_EXPRESSION_MAP.get(copyright_license, copyright_license) }}"
license-files = ["LICENSE"]
{%- endif %}
readme = "README.md"
requires-python = ">={{ python_min_version }}"
dependencies = []

classifiers = [
    "Typing :: Typed",
    "Operating System :: OS Independent",
    "Intended Audience :: Developers",
    "Topic :: Software Development :: Libraries :: Python Modules",
    "Programming Language :: Python",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3 :: Only",
{%- for classifier in py_classifiers(python_min_version, python_max_version) %}
    "{{ classifier }}",
{%- endfor %}
]

keywords = [
    "{{ package_name }}"
]

[project.optional-dependencies]
test = ["pytest>=8.4.2", "coverage>=7.13.1"]
dev = [
    "pytest>=8.4.2",
    "coverage>=7.13.1",
    "ruff==0.15.8",
    "pre-commit>=4.5.1",
    "pyrefly>=1.0.0",
    "codespell>=2.4.1",
    "rattle-lint>=2.4.2",
]
{% if setup_readthedocs %}
docs = [
    "beautifulsoup4",
    "furo",
    "jinja2 == 3.1.6",
    "myst-parser == 4.0.1",
    "sphinx == 8.0.2",
    "sphinx-copybutton",
    "sphinx-notfound-page",
    "sphinxcontrib-mermaid",
    "sphinxext-opengraph",
]
{% endif %}

[dependency-groups]
test = ["pytest>=8.4.2", "coverage>=7.13.1"]
dev = [
    { include-group = "test" },
    "ruff==0.15.8",
    "pre-commit>=4.5.1",
    "pyrefly>=1.0.0",
    "codespell>=2.4.1",
    "rattle-lint>=2.4.2",
]

[tool.uv]
default-groups = ["test"]

[project.urls]
Repository = "{{ repository_url }}"
Issues = "{{ repository_url }}/issues"
Homepage = "{{ repository_url }}"
{% if setup_readthedocs %}
Documentation = "https://{{ repo_name }}.readthedocs.io"
{% endif %}

[build-system]
requires = ["uv_build>=0.11.25,<0.12.0"]
build-backend = "uv_build"

[tool.uv.build-backend]
module-name = "{{ package_name }}"
module-root = ""

[tool.coverage.run]
source = ["{{ package_name }}"]
branch = true

[tool.coverage.report]
exclude_lines = [
    'pragma: no cover',
    'raise NotImplementedError',
    'if TYPE_CHECKING:',
    'if typing.TYPE_CHECKING:',
]
omit = [
    "tests/*",
    "tests/**",
]

[tool.pyrefly]
project-includes = ["{{ package_name }}"]
project-excludes = ["tests/**"]
search-path = ["."]
disable-search-path-heuristics = true
python-version = "{{ python_min_version }}"
enabled-ignores = ["type", "pyrefly"]
use-ignore-files = true
check-unannotated-defs = true
infer-return-types = "checked"
infer-with-first-use = true
strict-callable-subtyping = false
spec-compliant-overloads = false

[tool.rattle]
root = true
enable = [
    "blank-line-after-control-block",
    "blank-line-after-terminal-control-block",
    "blank-line-before-branch",
    "blank-line-before-unrelated-block",
    "no-suite-leading-trailing-blank-lines",
    "module-all-at-bottom",
    "no-underscore-all-exports",
    "forbidden-call",
    "no-relative-imports",
    "no-underscore-import-aliases",
    "no-unsafe-tempfile-factories",
    "no-annotated-self",
    "no-exception-message-variables",
    "no-str-exception-translation",
    "no-underscore-class",
    "public-method-order",
    "no-bare-object-annotations",
    "no-named-tuple",
    "no-static-if-condition",
    "sorted-attributes",
    "use-callable-ellipsis",
]

[tool.rattle.options."forbidden-call"]
forbidden_calls = ["typing.cast"]

[tool.ruff]
line-length = 100

[tool.ruff.lint]
select = ["ALL"]
ignore = [
    "ERA",
    "FBT002",
    "COM",
    "CPY",
    "DJ",
    "ANN003",
    "FIX",
    "D100",
    "D101",
    "D102",
    "D103",
    "D104",
    "D105",
    "D106",
    "D107",
    "D205",
    "D203",
    "D212",
    "E501",
    "PIE804",
    "S101",
    "EM101",
    "PYI041",
    "PYI051",
    "PYI046",
    "PYI047",
    "PYI049",
    "PYI053",
    "PYI054",
    "RET501",
    "SIM910",
    "N812",
    "PLC0415",
    "PLR0904",
    "PLR0913",
    "PLR2004",
    "PLR1711",
    "TRY003",
    "T20",
    "SIM105",
    "RET504",
    "PLR0912",
    "PLR0915",
    "TD",
    "TC001",
    "TC002",
    "TC003",
    "TC006",
    "PLW0603",
    "EM102",
    "PLW2901",
    "RSE102",
    "PGH004",
    "N806",
    "FBT001",
]
exclude = ["build"]

[tool.ruff.lint.per-file-ignores]
"__init__.py" = [
    "F401", # Unused import
    "E402", # Module import not at top of file
]
{% if setup_readthedocs %}
"docs/conf.py" = ["A001", "INP001"]
"docs/_ext/darker_modern_pygments.py" = ["RUF012"]
{% endif %}
"**/tests/**/*.py" = [
    "S104",
    "S105",
    "S106",
    "TRY004",
    "RUF003",
    "RUF012",
    "UP031",
    "SLF001",
    "ARG",
    "N806",
    "ANN001",
    "ANN201",
    "ANN202",
    "ANN204",
    "ANN401",
    "S",
    "INP001",
    "PLW0108",
    "EM102",
    "FBT001",
    "SIM300",
    "FLY002",
    "A002",
    "A004",
]
"examples/*.py" = ["INP001"]

[tool.ruff.lint.pep8-naming]
classmethod-decorators = [
    "pydantic.validator",
    "declared_attr",
    "expression",
    "comparator",
]

[tool.ruff.lint.flake8-builtins]
ignorelist = ["id", "input"]

[tool.ruff.lint.flake8-type-checking]
runtime-evaluated-base-classes = [
    "pydantic.BaseModel",
    "sqlalchemy.orm.DeclarativeBase",
]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"
skip-magic-trailing-comma = false
line-ending = "lf"

[tool.ruff.lint.isort]
known-first-party = ["{{ package_name }}", "tests"]

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.codespell]
skip = '.git,uv.lock'
